<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_achievement.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/achievementRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:clickable="true">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardAchievement"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="#1A0000"
        app:cardCornerRadius="24dp"
        app:cardElevation="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆 НОВОЕ ЗВАНИЕ! 🏆"
                android:textSize="14sp"
                android:textColor="@color/colorGold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.3" />

            <TextView
                android:id="@+id/tvAchievementEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😈"
                android:textSize="72sp"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tvAchievementTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ПОВЕЛИТЕЛЬ ПЕРЕСДАЧ"
                android:textSize="26sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/colorAccent"
                android:gravity="center"
                android:shadowColor="#FF0000"
                android:shadowRadius="15"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvAchievementDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Студенты видят тебя в кошмарах"
                android:textSize="14sp"
                android:textColor="@color/colorTextSecondary"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Нажми, чтобы продолжить карать"
                android:textSize="11sp"
                android:textColor="@color/colorTextHint"
                android:layout_marginTop="24dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/konfettiViewAchievement"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
