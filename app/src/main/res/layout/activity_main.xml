<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_main.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Заголовок приложения -->
    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="☠️ ДАРТ ВЕЙДЕР СИЯ КАИТА ☠️"
        android:textSize="18sp"
        android:fontFamily="sans-serif-black"
        android:textColor="@color/colorAccent"
        android:letterSpacing="0.1"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Карточка звания -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardRank"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/colorCardBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ТЕКУЩЕЕ ЗВАНИЕ"
                android:textSize="10sp"
                android:textColor="@color/colorTextHint"
                android:letterSpacing="0.3"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎓 Тун-Тун Отчислюн"
                android:textSize="18sp"
                android:textColor="@color/colorGold"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvNextRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="До следующего звания: 9 двоек"
                android:textSize="11sp"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvCounterLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/total_grades_label"
        android:textSize="11sp"
        android:textColor="@color/colorTextHint"
        android:letterSpacing="0.2"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/cardRank"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="80sp"
        android:fontFamily="sans-serif-black"
        android:textColor="@color/colorAccent"
        android:shadowColor="#FF0000"
        android:shadowRadius="25"
        android:shadowDx="0"
        android:shadowDy="0"
        app:layout_constraintTop_toBottomOf="@id/tvCounterLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tvFeedbackMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="@color/colorTextSecondary"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:alpha="0"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvCounter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/btnGiveGrade"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:text="@string/btn_give_grade"
        style="@style/Widget.GradeButton"
        app:layout_constraintTop_toBottomOf="@id/tvFeedbackMessage"
        app:layout_constraintBottom_toTopOf="@id/btnStats"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <com.grader.simulator.utils.ParticleView
        android:id="@+id/particleView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnStats"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="@string/stats_button"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="#1A0000"
        android:textColor="@color/colorTextSecondary"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:strokeColor="@color/colorDivider"
        app:strokeWidth="1dp" />

    <!-- Конфетти оверлей -->
    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/konfettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
